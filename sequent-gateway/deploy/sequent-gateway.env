# /etc/sequent-gateway/sequent-gateway.env
# Environment variables for the sequent-gateway systemd service.
# Edit these values to match your hardware configuration.

# Modbus TCP bind address and port
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=502

# I²C stack levels (0–7)
IND_STACK=1
RELAY_STACK=0

# Path to board definition TOML files
BOARDS_DIR=/etc/sequent-gateway/boards

# Heartbeat log interval (seconds)
LOG_INTERVAL=5

# Logging level (trace, debug, info, warn, error)
# Uncomment to override the default (info):
# RUST_LOG=sequent_gateway=debug
